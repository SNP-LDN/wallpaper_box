{
  "name": "wallpaper-local-library",
  "version": "1.4.5",
  "description": "壁纸盒：本地 Wallpaper 壁纸文件夹管理器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "npm run dist:installer",
    "dist:installer": "electron-builder --win nsis -c.artifactName=\"wallpaper_box-${version}-setup.${ext}\"",
    "dist:portable": "electron-builder --win portable --publish never -c.directories.output=dist-portable -c.artifactName=\"wallpaper_box-${version}-portable.${ext}\"",
    "dist:all": "npm run dist:installer && npm run dist:portable"
  },
  "devDependencies": {
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.wallpaperbox.app",
    "productName": "壁纸盒",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SNP-LDN",
        "repo": "wallpaper_box"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "support_me/**/*",
      "USER_GUIDE.md",
      "CHANGELOG.md",
      "README_EXE.txt",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
